# Copy this file to `.env` and fill in your real key.
#   PowerShell:  Copy-Item .env.example .env
# `.env` is gitignored, so your real key never gets committed.
#
# Get a key at https://console.anthropic.com (Billing must be set up — the
# live tests draw down API credits, separate from any Pro/Max subscription).
#
# Only the live agent tests need this; the default suite (pytest -m "not live")
# runs without it.

ANTHROPIC_API_KEY=sk-ant-your-key-here

# --- Publishing to PyPI with twine (optional) ---
# twine reads these two env vars for auth. Username is the literal "__token__";
# password is your API token from pypi.org (or test.pypi.org for the dry-run).
# Load them into PowerShell with:  . .\load_env.ps1
TWINE_USERNAME=__token__
TWINE_PASSWORD=pypi-your-token-here
